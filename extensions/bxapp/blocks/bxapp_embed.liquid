{% comment %}
  BXApp Unified Bundle Embed
  Renders bundle widgets on product pages + auto-add reward logic on all pages.
  Merchants only need to enable this single embed in Theme Settings → App Embeds.
{% endcomment %}

<script>window.__bxappApiBase={{ shop.metafields.bxgy_bundle.app_url.value | default: '' | json }};</script>

{% comment %} ── Bundle widgets (product pages only) ── {% endcomment %}
{% if request.page_type == 'product' %}
  {% assign bxapp_widget_id = 'bxapp-embed' %}

  <div id="bxapp-bundle-widgets" style="display:none;">
    <div data-bxapp-widget="tiered">
      {% render 'bxapp_tiered', product: product, bxapp_widget_id: bxapp_widget_id %}
    </div>
    <div data-bxapp-widget="volume">
      {% render 'bxapp_volume', product: product, bxapp_widget_id: bxapp_widget_id %}
    </div>
    <div data-bxapp-widget="complement">
      {% render 'bxapp_complement', product: product, bxapp_widget_id: bxapp_widget_id %}
    </div>
  </div>

  <script>
  (function() {
    // Skip auto-injection if the draggable app block is already placed
    if (document.querySelector('[data-bxapp-placed]')) {
      var c = document.getElementById('bxapp-bundle-widgets');
      if (c) c.remove();
      return;
    }

    var container = document.getElementById('bxapp-bundle-widgets');
    if (!container) return;

    // Remove empty widget wrappers
    var widgets = container.querySelectorAll('[data-bxapp-widget]');
    var hasContent = false;
    for (var i = 0; i < widgets.length; i++) {
      if (widgets[i].innerHTML.trim().length === 0) {
        widgets[i].remove();
      } else {
        hasContent = true;
      }
    }
    if (!hasContent) { container.remove(); return; }

    // Find the quantity/buttons area to inject ABOVE it.
    // We look for the outermost wrapper first, then drill down to inner elements.
    var anchorEl = null;
    var qtyWrapperSelectors = [
      'form[action*="/cart/add"] .product-form__quantity',
      'form[action*="/cart/add"] .quantity-selector',
      '.product-form__quantity'
    ];
    for (var q = 0; q < qtyWrapperSelectors.length; q++) {
      anchorEl = document.querySelector(qtyWrapperSelectors[q]);
      if (anchorEl) break;
    }

    // If no wrapper found, try inner quantity elements and walk up to their form-level parent
    if (!anchorEl) {
      var qtyInnerSelectors = [
        'form[action*="/cart/add"] quantity-input',
        'form[action*="/cart/add"] .quantity',
        'form[action*="/cart/add"] [name="quantity"]'
      ];
      for (var qi = 0; qi < qtyInnerSelectors.length; qi++) {
        var inner = document.querySelector(qtyInnerSelectors[qi]);
        if (inner) {
          // Walk up to the nearest .product-form__input or direct form child
          var parent = inner.parentElement;
          while (parent && parent.tagName !== 'FORM') {
            if (parent.classList.contains('product-form__input') || parent.classList.contains('product-form__quantity')) {
              anchorEl = parent;
              break;
            }
            parent = parent.parentElement;
          }
          if (!anchorEl) anchorEl = inner;
          break;
        }
      }
    }

    // Fallback: buttons
    if (!anchorEl) {
      var btnSelectors = [
        'form[action*="/cart/add"] .product-form__buttons',
        'form[action*="/cart/add"] .product-form__submit',
        'form[action*="/cart/add"] [name="add"]',
        'form[action*="/cart/add"] button[type="submit"]',
        '.product-form__buttons',
        '.product-form__submit'
      ];
      for (var b = 0; b < btnSelectors.length; b++) {
        anchorEl = document.querySelector(btnSelectors[b]);
        if (anchorEl) break;
      }
    }

    // Last fallback: form or product wrapper
    if (!anchorEl) {
      var fallbackSelectors = [
        'form[action*="/cart/add"]',
        '.product-form',
        '.product__info-wrapper',
        '[data-product-form]'
      ];
      for (var f = 0; f < fallbackSelectors.length; f++) {
        anchorEl = document.querySelector(fallbackSelectors[f]);
        if (anchorEl) break;
      }
    }

    if (!anchorEl) {
      container.style.display = '';
      return;
    }

    // Insert before the anchor element (quantity selector or buttons)
    container.style.display = '';
    container.style.marginBottom = '16px';
    anchorEl.parentNode.insertBefore(container, anchorEl);
  })();
  </script>
{% endif %}

{% comment %} ── Legacy BXGY Auto-Add removed (active_bundles metafield no longer used) ── {% endcomment %}

{% schema %}
{
  "name": "BXApp Bundles",
  "target": "body",
  "settings": []
}
{% endschema %}

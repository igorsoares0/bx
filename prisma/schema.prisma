// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}


model TieredBundle {
  id               Int      @id @default(autoincrement())
  name             String
  triggerType      String   @default("product") // "product" | "collection" | "all"
  productId        String   // JSON array de Shopify GIDs ou GID único (backward compat)
  triggerReference String?  // Shopify GID da coleção (quando triggerType=collection)
  tiersConfig      String   @default("[{\"buyQty\":1,\"freeQty\":1,\"discountPct\":100},{\"buyQty\":2,\"freeQty\":3,\"discountPct\":100},{\"buyQty\":3,\"freeQty\":6,\"discountPct\":100}]") // JSON array: [{ buyQty, freeQty, discountPct }, ...]
  active           Boolean  @default(true)
  shopId           String
  discountId       String?  // GID do automatic discount criado no Shopify
  designConfig     String?  // JSON com configurações de design
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model VolumeBundle {
  id               Int      @id @default(autoincrement())
  name             String
  triggerType      String   @default("product") // "product" | "collection" | "all"
  productId        String   // JSON array de Shopify GIDs ou GID único (backward compat)
  triggerReference String?  // Shopify GID da coleção (quando triggerType=collection)
  volumeTiers      String   @default("[{\"label\":\"Single\",\"qty\":1,\"discountPct\":0,\"popular\":false},{\"label\":\"Duo\",\"qty\":2,\"discountPct\":15,\"popular\":true},{\"label\":\"Trio\",\"qty\":3,\"discountPct\":25,\"popular\":false}]")
  active           Boolean  @default(true)
  shopId           String
  discountId       String?
  designConfig     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ComplementBundle {
  id               Int      @id @default(autoincrement())
  name             String
  triggerType      String   // "product" | "collection" | "all"
  triggerReference String?  // Shopify GID do produto ou coleção (null se "all")
  complements      String   // JSON: [{ productId, discountPct }]
  mode             String   @default("fbt") // "fbt" | "combo"
  triggerDiscountPct Int    @default(0) // discount % on trigger product (combo mode)
  active           Boolean  @default(true)
  shopId           String
  discountId       String?
  designConfig     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Billing ──

model ShopBilling {
  id                 Int      @id @default(autoincrement())
  shopId             String   @unique
  currentPlan        String   @default("Free")
  subscriptionId     String?
  subscriptionStatus String?
  isTrialing         Boolean  @default(false)
  lastSyncedAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ProcessedWebhookDelivery {
  id        Int      @id @default(autoincrement())
  webhookId String   @unique
  shopId    String
  topic     String
  createdAt DateTime @default(now())
}

model ProcessedRefund {
  id        Int      @id @default(autoincrement())
  shopId    String
  refundId  String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([shopId, refundId])
}

// ── Analytics ──

model BundleEvent {
  id         Int      @id @default(autoincrement())
  shopId     String
  eventType  String   // "view" | "click" | "add_to_cart"
  bundleType String   // "tiered" | "volume" | "complement"
  bundleId   Int?
  productId  String?  // Shopify product GID where the widget was shown
  createdAt  DateTime @default(now())

  @@index([shopId, eventType, createdAt])
  @@index([shopId, createdAt])
}

model BundleOrder {
  id              Int      @id @default(autoincrement())
  shopId          String
  orderId         String   @unique // Shopify order GID
  orderName       String?  // e.g. "#1001"
  bundleType      String   // "tiered" | "volume" | "complement"
  bundleId        Int?
  totalPrice      Int      @default(0) // order total in cents
  bundleRevenue   Int      @default(0) // revenue from bundle items in cents
  createdAt       DateTime @default(now())

  @@index([shopId, createdAt])
}

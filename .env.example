# Database connection (Neon PostgreSQL)
# Dev and prod use separate databases
DATABASE_URL='postgresql://user:password@host/dbname?sslmode=require'

# Shopify app credentials (set automatically by `shopify app dev`, or manually for production)
SHOPIFY_API_KEY='your-app-client-id'
SHOPIFY_API_SECRET='your-app-secret'
SCOPES='read_discounts,write_discounts,write_products,read_orders'
